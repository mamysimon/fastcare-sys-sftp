		<artifactId>paradiso-parent-pom</artifactId>
		<version>1.0.0</version>
	</parent>
	<groupId>43c948fb-024c-4176-a702-879840dedb82</groupId>
	<artifactId>sys-sftp</artifactId>
	<version>1.0.0</version>
	<packaging>mule-application</packaging>

	<name>sys-sftp</name>
	<build>
		<plugins>
			<plugin>
				<groupId>org.mule.tools.maven</groupId>
				<artifactId>mule-maven-plugin</artifactId>
				<version>${mule.maven.plugin.version}</version>
				<extensions>true</extensions>
				<configuration>
					<classifier>mule-application</classifier>
				</configuration>
			</plugin>
		</plugins>
	</build>
	<description/>
	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

		<app.runtime>4.11.0</app.runtime>
		<tags/>
		<categories>[]</categories>
		<fields>[]</fields>
		<mule.maven.plugin.version>4.7.0</mule.maven.plugin.version>
	</properties>

	<dependencies>
		<dependency>
			<groupId>43c948fb-024c-4176-a702-879840dedb82</groupId>
			<artifactId>sftp-system-api</artifactId>
			<version>1.0.3</version>
			<classifier>raml</classifier>
			<type>zip</type>
		</dependency>
	</dependencies>

	<repositories>
		<repository>
			<id>anypoint-exchange-v3</id>
			<name>Anypoint Exchange</name>
			<url>https://maven.anypoint.mulesoft.com/api/v3/maven</url>
			<layout>default</layout>
		</repository>
	</repositories>
</project>
