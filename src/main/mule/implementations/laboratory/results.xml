<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:sftp="http://www.mulesoft.org/schema/mule/sftp" xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/sftp http://www.mulesoft.org/schema/mule/sftp/current/mule-sftp.xsd">
	<sub-flow name="sub-get-laboratory-results" doc:id="537d63c7-2f9f-4ddf-95c1-caddcd75c4f4" >
		<try doc:name="Try" doc:id="6f17c3bc-ed7f-4877-b206-8dc6bb7bf6d6" >
			<sftp:read doc:name="Retrieve patient [results]" doc:id="5f068f5c-3082-4792-9252-43282a90f22d" config-ref="SFTP_Config" path='#["laboratory/results/$(vars.patientId).csv"]' outputMimeType='application/csv; separator=";"' target="results" />
			<error-handler >
				<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="fb418ef6-52b3-4ef1-a837-aaa4137f9898" >
					<set-variable value="#[[]]" doc:name="[results]" doc:id="b1f80d80-36c5-49c2-bc25-bd31486e7e8b" variableName="results"/>
				</on-error-continue>
			</error-handler>
		</try>
		<logger level="INFO" doc:name="After retrieve results" doc:id="18e53654-a21e-4756-a93e-294c5565dc6b" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;    step: "After retrieve results",&#10;    data: {&#10;        business: {&#10;        	patientFile: "$(vars.patientId).csv",&#10;        	countResults: sizeOf(vars.results)&#10;        },&#10;        technical: {}&#10;    }&#10;}]' category="${app.name}" />
		<logger level="DEBUG" doc:name="Debug retrieve results" doc:id="f7593c82-1fca-48e4-a2c7-95ed181ef397" message='#[%dw 2.0&#10;output application/json indent=false&#10;---&#10;{&#10;    step: "Debug retrieve results",&#10;    data: {&#10;        business: {},&#10;        technical: {&#10;        	firstResult: vars.results[0]&#10;        }&#10;    }&#10;}]' category="${app.name}" />
		<set-payload value="#[vars.results]" doc:name="Set Results" doc:id="0fc4c48e-8fb7-41b2-a9aa-9a0f32bd4b90" />
	</sub-flow>
</mule>
