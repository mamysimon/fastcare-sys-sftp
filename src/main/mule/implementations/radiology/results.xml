<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:sftp="http://www.mulesoft.org/schema/mule/sftp" xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/sftp http://www.mulesoft.org/schema/mule/sftp/current/mule-sftp.xsd">
	<sub-flow name="sub-get-radiology-results" doc:id="e2ee5114-6178-4fc0-a14b-37fa664d10a5" >
		<try doc:name="Try" doc:id="78fc6e67-1daa-4739-8c31-eaed14371803" >
			<sftp:read doc:name="Retrieve patient [results]" doc:id="4540b4b2-056f-4242-b2e1-d681d3b4138f" config-ref="SFTP_Config" path='#["radiology/results/$(vars.patientId).csv"]' outputMimeType='application/csv; separator=";"' target="results" />
			<error-handler >
				<on-error-continue enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="c6cf81e0-b26c-45a8-bc40-b46efc9085df" >
					<set-variable value="#[[]]" doc:name="[results]" doc:id="d1181fc8-c1ec-4158-b183-a04f81bd68a3" variableName="results" />
				</on-error-continue>
			</error-handler>
		</try>
		<logger level="INFO" doc:name="After retrieve results" doc:id="73f430f6-bea6-4f03-acfc-fedb1dfc16d9" message='#[%dw 2.0&#10;output application/json&#10;---&#10;{&#10;    step: "After retrieve results",&#10;    data: {&#10;        business: {&#10;        	patientFile: "$(vars.patientId).csv",&#10;        	countResults: sizeOf(vars.results)&#10;        },&#10;        technical: {}&#10;    }&#10;}]' category="${app.name}" />
		<logger level="DEBUG" doc:name="Debug retrieve results" doc:id="77aaabd4-a5ab-4be2-a11e-c40070bd418b" message='#[%dw 2.0&#10;output application/json indent=false&#10;---&#10;{&#10;    step: "Debug retrieve results",&#10;    data: {&#10;        business: {},&#10;        technical: {&#10;        	firstResult: vars.results[0]&#10;        }&#10;    }&#10;}]' category="${app.name}" />
		<set-payload value="#[vars.results]" doc:name="Set Results" doc:id="a26f769a-7de6-4a34-91de-c8355ecc97c2" />
	</sub-flow>
</mule>
